# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# Logging
LOG_LEVEL=INFO

# Cognito (populated after deployment)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# S3 Buckets (populated after deployment)
S3_BUCKET_STYLE_VAULT=
S3_BUCKET_ORIGINAL_CONTENT=
S3_BUCKET_TRANSCRIPTS=
S3_BUCKET_GENERATED_CONTENT=

# DynamoDB Tables
DYNAMODB_TABLE_USERS=users
DYNAMODB_TABLE_STYLE_CONTENT=style_content
DYNAMODB_TABLE_ORIGINAL_CONTENT=original_content
DYNAMODB_TABLE_GENERATED_CONTENT=generated_content
DYNAMODB_TABLE_SCHEDULED_POSTS=scheduled_posts

# Bedrock
BEDROCK_REGION=us-east-1
KNOWLEDGE_BASE_ID=
